{
  "tests": [
    {
      "name": "join, no argument",
      "expression": "a | join",
      "data": {
        "a": [1, 2, 3]
      },
      "result": "1 2 3"
    },
    {
      "name": "join, positional argument, string literal",
      "expression": "a | join: ','",
      "data": {
        "a": [1, 2, 3]
      },
      "result": "1,2,3"
    },
    {
      "name": "join, positional argument, variable",
      "expression": "a | join: b",
      "data": {
        "a": [1, 2, 3],
        "b": ","
      },
      "result": "1,2,3"
    },
    {
      "name": "join, positional argument, variable with path",
      "expression": "a | join: b.c",
      "data": {
        "a": [1, 2, 3],
        "b": { "c": "," }
      },
      "result": "1,2,3"
    },
    {
      "name": "join, positional argument, filtered",
      "expression": "a | join: (b | upcase)",
      "data": {
        "a": [1, 2, 3],
        "b": "a"
      },
      "result": "1A2A3"
    },
    {
      "name": "join, positional argument, logical",
      "expression": "a | join: (b or c)",
      "data": {
        "a": [1, 2, 3],
        "b": null,
        "c": ","
      },
      "result": "1,2,3"
    }
  ]
}
