{
  "tests": [
    {
      "name": "literal, single quotes",
      "expression": "{'a': 1, 'b': 2}",
      "result": "{\"a\":1,\"b\":2}"
    },
    {
      "name": "literal, double quotes",
      "expression": "{\"a\": 1, \"b\": 2}",
      "result": "{\"a\":1,\"b\":2}"
    },
    {
      "name": "literal, unquoted",
      "expression": "{a: 1, b: 2}",
      "result": "{\"a\":1,\"b\":2}"
    },
    {
      "name": "literal, empty",
      "expression": "{}",
      "result": "{}"
    },
    {
      "name": "literal, nested",
      "expression": "{'a': 1, 'b': {'c': 3}}",
      "result": "{\"a\":1,\"b\":{\"c\":3}}"
    },
    {
      "name": "literal, interpolated key",
      "expression": "{'${a}': 1}",
      "result": "{\"${a}\":1}"
    },
    {
      "name": "literal, spread, trailing",
      "expression": "{'c': 3, ...x}",
      "data": {
        "x": { "a": 1, "b": 2 }
      },
      "result": "{\"c\":3,\"a\":1,\"b\":2}"
    },
    {
      "name": "literal, spread, leading",
      "expression": "{...x, 'c': 3}",
      "data": {
        "x": { "a": 1, "b": 2 }
      },
      "result": "{\"a\":1,\"b\":2,\"c\":3}"
    },
    {
      "name": "literal, spread, middle",
      "expression": "{'c': 3, ...x, 'd': 4}",
      "data": {
        "x": { "a": 1, "b": 2 }
      },
      "result": "{\"c\":3,\"a\":1,\"b\":2,\"d\":4}"
    },
    {
      "name": "literal, spread, only",
      "expression": "{...x}",
      "data": {
        "x": { "a": 1, "b": 2 }
      },
      "result": "{\"a\":1,\"b\":2}"
    },
    {
      "name": "literal, nested arrays",
      "expression": "{'a': [1, 2, 3], 'b': {'c': [4, 5, 6]}}",
      "result": "{\"a\":[1,2,3],\"b\":{\"c\":[4,5,6]}}"
    }
  ]
}
