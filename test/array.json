{
  "tests": [
    {
      "name": "literal, integers",
      "expression": "[1, 2, 3]",
      "result": "[1,2,3]"
    },
    {
      "name": "literal, single element variable, trailing comma",
      "expression": "[a,]",
      "data": { "a": "b" },
      "result": "[\"b\"]"
    },
    {
      "name": "empty",
      "expression": "[]",
      "result": "[]"
    },
    {
      "name": "just a comma",
      "expression": "[,]",
      "result": "[]"
    }
  ]
}
