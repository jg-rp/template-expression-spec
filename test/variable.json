{
  "tests": [
    {
      "name": "shorthand",
      "expression": "a",
      "data": {
        "a": 42
      },
      "result": "42"
    },
    {
      "name": "bracketed, single quotes",
      "expression": "['a']",
      "data": {
        "a": 42
      },
      "result": "42"
    },
    {
      "name": "bracketed, double quotes",
      "expression": "[\"a\"]",
      "data": {
        "a": 42
      },
      "result": "42"
    },
    {
      "name": "bracketed, not a name, double quotes",
      "expression": "[\"some thing\"]",
      "data": {
        "some thing": 42
      },
      "result": "42"
    },
    {
      "name": "shorthand selector",
      "expression": "a.b",
      "data": {
        "a": { "b": 42 }
      },
      "result": "42"
    },
    {
      "name": "bracketed selector, single quotes",
      "expression": "a['b']",
      "data": {
        "a": { "b": 42 }
      },
      "result": "42"
    },
    {
      "name": "bracketed selector, double quotes",
      "expression": "a[\"b\"]",
      "data": {
        "a": { "b": 42 }
      },
      "result": "42"
    },
    {
      "name": "bracketed selector, singular query",
      "expression": "a[b]",
      "data": {
        "a": { "c": 42 },
        "b": "c"
      },
      "result": "42"
    },
    {
      "name": "bracketed selector, singular query, segments",
      "expression": "a[b.c['d']]",
      "data": {
        "a": { "e": 42 },
        "b": { "c": { "d": "e" } }
      },
      "result": "42"
    },
    {
      "name": "predicate, defined",
      "expression": "a.b.defined?",
      "data": {
        "a": { "b": 42 }
      },
      "result": "true"
    },
    {
      "name": "bracketed then predicate, defined",
      "expression": "['a']['b'].defined?",
      "data": {
        "a": { "b": 42 }
      },
      "result": "true"
    },
    {
      "name": "parenthesized expression, shorthand selector",
      "expression": "(a or b).c",
      "data": {
        "a": null,
        "b": { "c": 42 }
      },
      "result": "42"
    },
    {
      "name": "parenthesized expression, index selector",
      "expression": "(a or b)[0]",
      "data": {
        "a": null,
        "b": [42, 1, 2]
      },
      "result": "42"
    },
    {
      "name": "reserved word prefix",
      "expression": "andrew",
      "data": {
        "andrew": 42
      },
      "result": "42"
    },
    {
      "name": "reserved word match",
      "expression": "and",
      "data": {
        "and": 7
      },
      "result": "7"
    },
    {
      "name": "reserved word paths",
      "expression": "and.or",
      "data": {
        "and": { "or": 42 }
      },
      "result": "42"
    }
  ]
}
